# Production Environment Configuration
NODE_ENV=production
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_API_URL=https://api.bibiere.com
NEXT_PUBLIC_SITE_URL=https://bibiere.com

# Performance settings
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true

# Security settings
NEXT_PUBLIC_CSP_REPORT_URI=https://api.bibiere.com/csp-report
NEXT_PUBLIC_ENABLE_SECURITY_HEADERS=true

# Feature flags
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_OFFLINE_MODE=true

# SEO settings
NEXT_PUBLIC_ENABLE_STRUCTURED_DATA=true
NEXT_PUBLIC_ENABLE_SITEMAP=true
NEXT_PUBLIC_ENABLE_ROBOTS=true

# Cache settings
NEXT_PUBLIC_CACHE_MAX_AGE=31536000
NEXT_PUBLIC_STATIC_CACHE_MAX_AGE=31536000

# Monitoring
NEXT_PUBLIC_SENTRY_DSN=${SENTRY_DSN}
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=${GOOGLE_ANALYTICS_ID}
NEXT_PUBLIC_HOTJAR_ID=${HOTJAR_ID}