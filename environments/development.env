# Development Environment Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Performance settings (disabled for development)
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=false
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=false

# Security settings (relaxed for development)
NEXT_PUBLIC_CSP_REPORT_URI=
NEXT_PUBLIC_ENABLE_SECURITY_HEADERS=false

# Feature flags (enable for testing)
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=false
NEXT_PUBLIC_ENABLE_OFFLINE_MODE=false
NEXT_PUBLIC_ENABLE_DEBUG_MODE=true

# SEO settings (disabled for development)
NEXT_PUBLIC_ENABLE_STRUCTURED_DATA=false
NEXT_PUBLIC_ENABLE_SITEMAP=false
NEXT_PUBLIC_ENABLE_ROBOTS=false

# Cache settings (disabled for development)
NEXT_PUBLIC_CACHE_MAX_AGE=0
NEXT_PUBLIC_STATIC_CACHE_MAX_AGE=0

# Development tools
NEXT_PUBLIC_ENABLE_REACT_DEVTOOLS=true
NEXT_PUBLIC_ENABLE_REDUX_DEVTOOLS=true